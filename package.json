{
  "name": "llm-trace-phoenix-otlp",
  "version": "1.2.2",
  "description": "OpenClaw plugin — sends LLM input/output traces to Arize Phoenix via OpenTelemetry OTLP gRPC",
  "main": "index.ts",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "keywords": [
    "openclaw",
    "opentelemetry",
    "phoenix",
    "llm",
    "tracing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ParinLL/llm-trace-phoenix-otlp.git"
  },
  "homepage": "https://github.com/ParinLL/llm-trace-phoenix-otlp#readme",
  "author": "ParinLL",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  },
  "bundledDependencies": [
    "@opentelemetry/api"
  ],
  "devDependencies": {
    "openclaw": "^2026.3.11"
  }
}
